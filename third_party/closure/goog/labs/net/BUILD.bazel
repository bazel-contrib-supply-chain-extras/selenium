# DO NOT EDIT -- bazel run //third_party/closure/goog:regenerate -- "$PWD"

load("@io_bazel_rules_closure//closure:defs.bzl", "closure_js_library")

package(default_visibility = ["//visibility:public"])

licenses(["notice"])

closure_js_library(
    name = "all_js",
    exports = [
        ":image",
        ":webchannel",
        ":webchanneltransport",
        ":webchanneltransportfactory",
        ":xhr",
        "//third_party/closure/goog/labs/net/webchannel:all_js",
    ],
)

closure_js_library(
    name = "image",
    srcs = ["image.js"],
    lenient = True,
    deps = [
        "//third_party/closure/goog/dom:safe",
        "//third_party/closure/goog/events:eventhandler",
        "//third_party/closure/goog/events:eventtype",
        "//third_party/closure/goog/html:safeurl",
        "//third_party/closure/goog/net:eventtype",
        "//third_party/closure/goog/promise",
        "//third_party/closure/goog/useragent",
    ],
)

closure_js_library(
    name = "webchannel",
    srcs = ["webchannel.js"],
    lenient = True,
    deps = [
        "//third_party/closure/goog/events",
        "//third_party/closure/goog/events:event",
        "//third_party/closure/goog/events:listenable",
        "//third_party/closure/goog/net:xmlhttpfactory",
    ],
)

closure_js_library(
    name = "webchanneltransport",
    srcs = ["webchanneltransport.js"],
    lenient = True,
)

closure_js_library(
    name = "webchanneltransportfactory",
    srcs = ["webchanneltransportfactory.js"],
    lenient = True,
    deps = [
        "//third_party/closure/goog/functions",
        "//third_party/closure/goog/labs/net/webchannel:webchannelbasetransport",
    ],
)

closure_js_library(
    name = "xhr",
    srcs = ["xhr.js"],
    lenient = True,
    deps = [
        "//third_party/closure/goog/asserts",
        "//third_party/closure/goog/debug:error",
        "//third_party/closure/goog/net:httpstatus",
        "//third_party/closure/goog/net:xmlhttp",
        "//third_party/closure/goog/object",
        "//third_party/closure/goog/promise",
        "//third_party/closure/goog/string",
        "//third_party/closure/goog/uri:utils",
        "//third_party/closure/goog/useragent",
    ],
)
